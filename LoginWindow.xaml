<Window x:Class="RussianLanguageTextbook.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="300" Width="300"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <TabControl x:Name="mainTabControl">
            <TabItem Header="Вход">
                <StackPanel Margin="10">
                    <TextBlock Text="Логин"/>
                    <TextBox x:Name="loginUsernameTextBox" Margin="0,0,0,10"/>
                    <TextBlock Text="Пароль"/>
                    <PasswordBox x:Name="loginPasswordBox" Margin="0,0,0,10"/>
                    <Button Content="Войти" Click="LoginButton_Click" Background="#2196F3" Foreground="White" Height="30"/>
                    <TextBlock x:Name="loginMessageText" Foreground="Red" Visibility="Collapsed" Margin="0,10,0,0"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Регистрация">
                <StackPanel Margin="10">
                    <TextBlock Text="Логин"/>
                    <TextBox x:Name="regUsernameTextBox" Margin="0,0,0,5"/>
                    <TextBlock Text="Пароль"/>
                    <PasswordBox x:Name="regPasswordBox" Margin="0,0,0,5"/>
                    <TextBlock Text="Повторите пароль"/>
                    <PasswordBox x:Name="regConfirmPasswordBox" Margin="0,0,0,10"/>
                    <Button Content="Зарегистрироваться" Click="RegisterButton_Click" Background="#4CAF50" Foreground="White" Height="30"/>
                    <TextBlock x:Name="registerMessageText" Foreground="Red" Visibility="Collapsed" Margin="0,10,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
