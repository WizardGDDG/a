
<Window x:Class="RussianLanguageTextbook.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учебник по русскому языку"
        Height="600" Width="850"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <StackPanel Grid.Row="0" Grid.Column="0" Background="#f0f0f0">
            <TextBlock Text="МЕНЮ" FontSize="18" FontWeight="Bold" Margin="10" TextAlignment="Center"/>

            <TextBlock Text="Разделы" FontWeight="Bold" Margin="10,5,10,2"/>
            <ListBox x:Name="sectionsListBox" Margin="10,0,10,10" Height="150" 
                     DisplayMemberPath="Title"
                     SelectionChanged="SectionsListBox_SelectionChanged"/>

            <!-- Кнопка для теста -->
            <Button x:Name="startTestButton" Content="Пройти тест" Margin="10,5" Click="StartTestButton_Click" Background="#4CAF50" Foreground="White" Height="30"/>

            <Button x:Name="leaderboardButton" Content="Таблица лидеров" Margin="10,5" Click="LeaderboardButton_Click" Background="#FF9800" Foreground="White" Height="30"/>

            <!-- Админ панель -->
            <StackPanel x:Name="adminPanel" Visibility="Collapsed" Margin="0,20,0,0">
                <Separator/>
                <TextBlock Text="АДМИНИСТРАТОР" FontWeight="Bold" Margin="10,5" HorizontalAlignment="Center"/>
                <Button Content="➕ Добавить раздел" Margin="10,2" Click="AddSection_Click" Background="#4CAF50" Foreground="White"/>
                <Button Content="✖ Удалить раздел" Margin="10,2" Click="DeleteSection_Click" Background="#F44336" Foreground="White"/>
                <Button Content="❓ Добавить вопрос" Margin="10,2" Click="AddQuestion_Click" Background="#2196F3" Foreground="White"/>
            </StackPanel>
        </StackPanel>

        <!-- Основной контент -->
        <Grid Grid.Row="0" Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="userInfoText" Text="Пользователь: " VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="userScoreText" Text="Очки: 0" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold" Foreground="#FF9800"/>
                <Button x:Name="logoutButton" Content="Выйти" Click="LogoutButton_Click" Padding="10,2" Background="#f44336" Foreground="White"/>
            </StackPanel>

            <!-- Контент -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="contentPanel" Margin="0,10,0,0">
                    <TextBlock x:Name="contentTitle" Text="Добро пожаловать!" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="contentText" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,20"/>

                    <!-- Панель добавления раздела -->
                    <StackPanel x:Name="addSectionPanel" Visibility="Collapsed" Margin="0,10,0,0">
                        <Border BorderBrush="#4CAF50" BorderThickness="2" Padding="10">
                            <StackPanel>
                                <TextBlock Text="НОВЫЙ РАЗДЕЛ" FontWeight="Bold" Foreground="#4CAF50"/>
                                <TextBox x:Name="newSectionTitle" Margin="0,10,0,5" Padding="5"/>
                                <TextBox x:Name="newSectionContent" Margin="0,0,0,10" Padding="5" Height="80" TextWrapping="Wrap"/>
                                <Button Content="Сохранить раздел" Click="SaveNewSection_Click" Background="#4CAF50" Foreground="White" Height="30"/>
                                <Button Content="Отмена" Click="CancelAddSection_Click" Background="#9E9E9E" Foreground="White" Margin="0,5,0,0" Height="30"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Панель добавления вопроса -->
                    <StackPanel x:Name="addQuestionPanel" Visibility="Collapsed" Margin="0,10,0,0">
                        <Border BorderBrush="#2196F3" BorderThickness="2" Padding="10">
                            <StackPanel>
                                <TextBlock Text="НОВЫЙ ВОПРОС" FontWeight="Bold" Foreground="#2196F3"/>
                                <TextBlock Text="Раздел:" Margin="0,10,0,2"/>
                                <TextBlock x:Name="currentSectionForQuestion" FontWeight="Bold" Margin="0,0,0,10"/>

                                <TextBlock Text="Вопрос:" Margin="0,0,0,2"/>
                                <TextBox x:Name="newQuestionText" Margin="0,0,0,10" Padding="5"/>

                                <TextBlock Text="Вариант 1 (правильный):" Margin="0,0,0,2"/>
                                <TextBox x:Name="newOption1" Margin="0,0,0,5" Padding="5"/>

                                <TextBlock Text="Вариант 2:" Margin="0,0,0,2"/>
                                <TextBox x:Name="newOption2" Margin="0,0,0,5" Padding="5"/>

                                <TextBlock Text="Вариант 3:" Margin="0,0,0,2"/>
                                <TextBox x:Name="newOption3" Margin="0,0,0,5" Padding="5"/>

                                <TextBlock Text="Вариант 4:" Margin="0,0,0,2"/>
                                <TextBox x:Name="newOption4" Margin="0,0,0,10" Padding="5"/>

                                <Button Content="Сохранить вопрос" Click="SaveQuestion_Click" Background="#2196F3" Foreground="White" Height="30"/>
                                <Button Content="Отмена" Click="CancelAddQuestion_Click" Background="#9E9E9E" Foreground="White" Margin="0,5,0,0" Height="30"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Панель теста -->
                    <StackPanel x:Name="testPanel" Visibility="Collapsed">
                        <StackPanel x:Name="optionsStackPanel" Margin="0,10,0,20"/>
                        <Button x:Name="checkAnswerButton" Content="Ответить" Click="CheckAnswerButton_Click" Background="#2196F3" Foreground="White" Padding="20,5" Height="35" Width="100" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Панель лидерборда -->
                    <StackPanel x:Name="leaderboardPanel" Visibility="Collapsed">
                        <TextBlock Text="🏆 ТАБЛИЦА ЛИДЕРОВ" FontSize="18" FontWeight="Bold" Foreground="#FF9800" Margin="0,0,0,15"/>
                        <ItemsControl x:Name="leaderboardList"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Строка состояния внизу -->
        <StatusBar Grid.Row="1" Grid.ColumnSpan="2" Background="#e0e0e0" Padding="5">
            <StatusBarItem>
                <TextBlock x:Name="statusText" Text="Готов к работе"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
